{
  "authenticationMethod": "route",
  "routes": [
    {
      "source": "^/session/link$",
      "destination": "s4-pp-mcp-backend",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^/mcp(.*)",
      "destination": "s4-pp-mcp-backend",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^/health$",
      "destination": "s4-pp-mcp-backend",
      "authenticationType": "none"
    },
    {
      "source": "^/whoami$",
      "target": "/whoami",
      "destination": "s4-pp-mcp-backend",
      "authenticationType": "xsuaa"
    },
    {
      "source": "^(.*)$",
      "target": "$1",
      "destination": "s4-pp-mcp-backend",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    }
  ]
}